# ===== 应用配置 =====
FRONTEND_PORT=80
APP_PORT=8080

# ===== 数据库配置 =====
MYSQL_ROOT_PASSWORD=rag123456
MYSQL_DATABASE=rag
MYSQL_PORT=3306

# ===== LLM 模型配置（按需填写） =====
# Embedding 模型配置（用于文档向量化，固定使用）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024

# 注意：Chat 模型通过系统管理界面动态配置，不在此处设置

# ===== MinIO 文件存储配置 =====
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===== Milvus 向量数据库配置 =====
MILVUS_PORT=19530

# ===== Redis 缓存配置 =====
REDIS_PORT=6379
